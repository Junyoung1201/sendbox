{
    "name": "sendbox-server",
    "version": "1.0.0",
    "author": "이준영",
    "description": "Sendbox server - E2E 공유 서비스",
    "main": "build/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node build/index.js",
        "start:dev": "cross-env NODE_ENV=development ts-node src/index.ts",
        "dev": "nodemon -e ts --watch ./src --exec npm run start:dev",
        "setup-db": "setup-database.bat"
    },
    "keywords": [
        "file-sharing",
        "encryption",
        "express"
    ],
    "license": "MIT",
    "dependencies": {
        "bcrypt": "^5.1.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "fs-extra": "^11.2.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "pg": "^8.11.3",
        "socket.io": "^4.6.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/cookie-parser": "^1.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/fs-extra": "^11.0.4",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.11.5",
        "@types/pg": "^8.10.9",
        "cross-env": "^10.1.0",
        "nodemon": "^3.1.14",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
}
